{
  "consumer": {
    "name": "ArrowMaze-Client"
  },
  "interactions": [
    {
      "description": "a login request",
      "providerStates": [
        {
          "name": "a user pact_user with password secret123 exists"
        }
      ],
      "request": {
        "body": {
          "password": "secret123",
          "username": "pact_user"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "method": "POST",
        "path": "/auth/login"
      },
      "response": {
        "body": {
          "accessToken": "jwt-token",
          "user": {
            "id": "4c6cf76a-0000-0000-0000-000000000000",
            "role": "user",
            "username": "pact_user"
          }
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.accessToken": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.user.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.user.role": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.user.username": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a progress sync request",
      "providerStates": [
        {
          "name": "an authenticated player exists"
        }
      ],
      "request": {
        "body": {
          "results": [
            {
              "levelId": 1,
              "score": 880
            }
          ]
        },
        "headers": {
          "Authorization": "Bearer jwt-token",
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "header": {
            "Authorization": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "Bearer .+"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/progress/sync"
      },
      "response": {
        "body": [
          {
            "bestScore": 880,
            "levelId": 1
          }
        ],
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$[*].bestScore": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$[*].levelId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            }
          }
        },
        "status": 201
      }
    },
    {
      "description": "a registration request",
      "providerStates": [
        {
          "name": "the username pact_user is available"
        }
      ],
      "request": {
        "body": {
          "password": "secret123",
          "username": "pact_user"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "method": "POST",
        "path": "/auth/register"
      },
      "response": {
        "body": {
          "accessToken": "jwt-token",
          "user": {
            "id": "4c6cf76a-0000-0000-0000-000000000000",
            "role": "user",
            "username": "pact_user"
          }
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.accessToken": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.user.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.user.role": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.user.username": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 201
      }
    },
    {
      "description": "a request for all level definitions",
      "providerStates": [
        {
          "name": "the level seed is loaded"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/levels"
      },
      "response": {
        "body": [
          {
            "cells": [
              {
                "col": 0,
                "kind": "EMPTY",
                "row": 0
              }
            ],
            "cols": 3,
            "difficulty": "EASY",
            "id": 1,
            "name": "First Steps",
            "rows": 3
          }
        ],
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$[*].cells": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$[*].cells[*].col": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$[*].cells[*].kind": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "ARROW|WALL|EMPTY|EXIT|COLLECTIBLE"
                }
              ]
            },
            "$[*].cells[*].row": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$[*].cols": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$[*].difficulty": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "EASY|MEDIUM|HARD"
                }
              ]
            },
            "$[*].id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$[*].name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].rows": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request for the level 1 leaderboard",
      "providerStates": [
        {
          "name": "scores exist on level 1"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/leaderboard/1",
        "query": {
          "limit": [
            "10"
          ]
        }
      },
      "response": {
        "body": [
          {
            "achievedAt": "2026-07-01T12:00:00.000Z",
            "levelId": 1,
            "score": 880,
            "username": "pact_user"
          }
        ],
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$[*].achievedAt": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].levelId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$[*].score": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$[*].username": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request for the overall ranking",
      "providerStates": [
        {
          "name": "scores exist on level 1"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/leaderboard",
        "query": {
          "limit": [
            "10"
          ]
        }
      },
      "response": {
        "body": [
          {
            "levelsPlayed": 1,
            "totalScore": 880,
            "username": "pact_user"
          }
        ],
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$[*].levelsPlayed": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$[*].totalScore": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$[*].username": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request for the player progress",
      "providerStates": [
        {
          "name": "an authenticated player exists"
        }
      ],
      "request": {
        "headers": {
          "Authorization": "Bearer jwt-token"
        },
        "matchingRules": {
          "header": {
            "Authorization": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "Bearer .+"
                }
              ]
            }
          }
        },
        "method": "GET",
        "path": "/progress"
      },
      "response": {
        "body": [
          {
            "bestScore": 880,
            "levelId": 1
          }
        ],
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$[*].bestScore": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$[*].levelId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "17.0.1"
    },
    "pactRust": {
      "ffi": "0.5.4",
      "models": "1.3.11"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "ArrowMaze-Backend"
  }
}